{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "web-builder",
  "main": "src/index.ts",
  "compatibility_date": "2025-01-01",

  "kv_namespaces": [
    {
      "binding": "METADATA",
      "id": "ID",
    },
  ],

  "r2_buckets": [
    {
      "binding": "FILES",
      "bucket_name": "builder-file",
    },
  ],
}
